# Copy to .env.local for development (do not commit real keys).

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# Slab faces per exemplar cert: default scales with exemplar count. Use `all` for every image in each DIG manifest.
# GEMINI_MAX_IMAGES_PER_EXEMPLAR=all

# Optional (Pokémon TCG thumbnails)
# POKEMONTCG_API_KEY=

# Override data paths (defaults under ./data/)
# DATA_ROOT=
# SQLITE_DB_PATH=
# Public HTTPS DB (R2, public Blob URL, etc.):
# SQLITE_DB_DOWNLOAD_URL=https://.../app.db
# Private Vercel Blob (store pathname, e.g. app.db — needs BLOB_READ_WRITE_TOKEN at runtime):
# SQLITE_BLOB_PATHNAME=app.db
# DIG_CACHE_ROOT=/absolute/path/outside/repo/dig_cache   # keeps slabs out of uploads for `vercel deploy`; optional in dev too
# Remote DIG slabs (HTTPS) — mirrors data/dig_cache/<cert_id>/ on object storage/CDN:
# DIG_EXEMPLAR_BASE_URL=https://your-cdn.example/dig-cache
# DIG_EXEMPLAR_PATH_PREFIX=en    # optional: ja, datasets/v2, ...
# DIG_EXEMPLAR_FETCH_AUTHORIZATION=Bearer ...   # optional private bucket
# Upload local dig_cache to Vercel Blob (public exemplar store) — token from Blob dashboard:
# EXEMPLAR_READ_WRITE_TOKEN=vercel_blob_rw_...
# npm run upload:exemplars-blob
# To remove uploaded exemplars from this Blob store only: npm run delete:exemplars-blob -- --confirm [--prefix=dig | --all]
# CERT_INDEX_PATH=
# CARD_URLS_PATH=
# Vercel-only: HTTPS URL to gzip-tar of inbox files (extracted to data/inbox/), then build:index runs
# VERCEL_INBOX_TAR_GZ_URL=
# VERCEL_INBOX_ARCHIVE_MAX_MB=750

