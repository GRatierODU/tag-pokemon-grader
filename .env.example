# Copy to .env.local for development (do not commit real keys).

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Optional (Pokémon TCG thumbnails)
# POKEMONTCG_API_KEY=

# Override data paths (defaults under ./data/)
# DATA_ROOT=
# SQLITE_DB_PATH=
# DIG_CACHE_ROOT=/absolute/path/outside/repo/dig_cache   # keeps slabs out of uploads for `vercel deploy`; optional in dev too
# CERT_INDEX_PATH=
# CARD_URLS_PATH=
